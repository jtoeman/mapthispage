{
  "manifest_version": 3,
  "name": "MapThisPage",
  "background": {
    "service_worker": "background.js"
  },
  "version": "1.3.0",
  "description": "Find addresses and open them in gmaps. Broad host permissions required to scan pages proactively and display an address count badge",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
